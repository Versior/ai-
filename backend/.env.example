# Versior AI 神经元电台 - 环境变量配置
# 复制此文件为 .env 并填写配置

# === LLM 配置（必填） ===
# 支持任何兼容 OpenAI 格式的 API（LongCat、OpenAI、DeepSeek 等）
LONGCAT_API_KEY=
LONGCAT_API_URL=
LONGCAT_MODEL=

# === 管理员密码 ===
ADMIN_PASSWORD=versior123

# === 音乐平台配置 ===
MUSIC_SOURCE=netease

# 网易云 Cookie（必填，用于搜索/播放链接/详情/热评）
# 获取方式：浏览器登录 music.163.com → F12 → Application → Cookies → 复制
NETEASE_COOKIE=

# 酷我 Cookie（可选）
# 获取方式：浏览器登录 kuwo.cn → F12 → Application → Cookies → 复制
KUWO_COOKIE=

# QQ音乐 Cookie（可选）
# 获取方式：浏览器登录 y.qq.com → F12 → Application → Cookies → 复制
# 必须包含 qm_keyst 或 qqmusic_key
QQMUSIC_COOKIE=

# 酷狗 Cookie（可选）
# 获取方式：浏览器登录 kugou.com → F12 → Application → Cookies → 复制
# 必须包含 kg_mid 或 kg_dfid
KUGOU_COOKIE=
