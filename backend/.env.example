# ============================================
# Versior AI 电台 - 环境变量模板
# ============================================
# 复制此文件为 .env 并填入实际值:
#   cp backend/.env.example backend/.env
# ============================================

# ========================
# 服务器配置
# ========================
PORT=8834
NODE_ENV=production
ADMIN_PASSWORD=change_me_to_strong_password

# ========================
# AI 配置（必填）
# ========================
LONGCAT_API_KEY=your_api_key_here
LONGCAT_API_URL=
LONGCAT_MODEL=

# ========================
# 音乐源配置
# ========================
# 搜索 API 地址（网易云第三方 API）
MUSIC_API_URL=
# 默认音乐源: netease | kuwo | qqmusic | kugou
MUSIC_SOURCE=netease

# ========================
# 网易云音乐
# ========================
# 方式一：Cookie 登录（推荐）
# 在浏览器登录 music.163.com → F12 → Application → Cookies → 复制所有值
NETEASE_COOKIE=

# 方式二：账号密码登录
NETEASE_USERNAME=
NETEASE_PASSWORD=

# ========================
# 酷我音乐
# ========================
KUWO_COOKIE=
KUWO_USERNAME=
KUWO_PASSWORD=

# ========================
# QQ音乐（仅 Cookie 方式）
# 在浏览器登录 y.qq.com → F12 → Application → Cookies
# Cookie 必须包含 qm_keyst 或 qqmusic_key
# ========================
QQMUSIC_COOKIE=

# ========================
# 酷狗音乐（仅 Cookie 方式）
# 在浏览器登录 www.kugou.com → F12 → Application → Cookies
# ========================
KUGOU_COOKIE=
