import React, { useState, useEffect, useRef } from 'react';
import { 
  Play, Pause, SkipBack, SkipForward, Square, 
  Volume2, Mic, ArrowUp, Info, Settings
} from 'lucide-react';

export default function App() {
  // --- 核心状态 ---
  const [theme, setTheme] = useState('dark');
  const [currentTime, setCurrentTime] = useState(new Date());
  const [wsConnected, setWsConnected] = useState(false);
  const [showIntro, setShowIntro] = useState(false);
  const [showSettings, setShowSettings] = useState(false);
  
  // --- 播放器状态 ---
  const [isPlaying, setIsPlaying] = useState(false);
  const [volume, setVolume] = useState(80);
  const [progress, setProgress] = useState(0); 
  const [duration, setDuration] = useState(0); 
  const [currentPlayTime, setCurrentPlayTime] = useState(0); 

  // --- 业务数据状态 ---
  const [inputText, setInputText] = useState("");
  const [isDJSpeaking, setIsDJSpeaking] = useState(false);
  const [djMessage, setDjMessage] = useState("我一直都在，在这个长夜为你打碟。让这首歌先慢慢流淌一会儿。接下来你想听点什么？");
  const [currentTrack, setCurrentTrack] = useState({
    title: "비행운", artist: "MoonMoon", cover: "", url: ""
  });
  const [queue, setQueue] = useState([
    { title: "비행운", artist: "MoonMoon", active: true },
    { title: "Creepin'", artist: "Tabber, Paul Blanco, MISO", active: false },
    { title: "Hero", artist: "Mili", active: false },
    { title: "Wine", artist: "SoulChef", active: false },
    { title: "天菜(prod.by Bubbleboy)", artist: "GAHO", active: false }
  ]);

  // --- Refs ---
  const audioRef = useRef(null);
  const wsRef = useRef(null);

  // --- 1. WebSocket 连接逻辑 ---
  useEffect(() => {
    let ws = null;
    try {
      const wsProtocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
      const wsHost = window.location.hostname || 'localhost';
      ws = new WebSocket(`${wsProtocol}//${wsHost}:8834`);
      wsRef.current = ws;

      ws.onopen = () => {
        setWsConnected(true);
      };

      ws.onmessage = (event) => {
        try {
          const data = JSON.parse(event.data);
          if (data.type === 'dj_broadcast') {
            if (data.say) {
              setDjMessage(data.say);
              playDJSynthesis(data.say, () => {
                if (data.track) loadAndPlayTrack(data.track);
              });
            } else if (data.track) {
              loadAndPlayTrack(data.track);
            }
            if (data.queue) setQueue(data.queue);
          }
        } catch (e) {
          console.error("WS 解析错误", e);
        }
      };
      ws.onclose = () => setWsConnected(false);
    } catch (error) {
      console.warn("WebSocket 连接被阻止:", error);
    }

    return () => {
      if (ws && ws.readyState === 1) ws.close();
    };
  }, []);

  // --- 2. 真实音频播放控制 ---
  const loadAndPlayTrack = (track) => {
    setCurrentTrack(track);
    if (audioRef.current && track.url) {
      audioRef.current.src = track.url;
      audioRef.current.play().then(() => setIsPlaying(true)).catch(e => console.log("自动播放被拦截", e));
    }
  };

  const togglePlay = () => {
    if (!audioRef.current) return;
    if (isPlaying) audioRef.current.pause();
    else audioRef.current.play();
    setIsPlaying(!isPlaying);
  };

  const handleVolumeChange = (e) => {
    const val = parseInt(e.target.value);
    setVolume(val);
    if (audioRef.current) audioRef.current.volume = val / 100;
  };

  const handleProgressChange = (e) => {
    const val = parseInt(e.target.value);
    setProgress(val);
    if (audioRef.current && duration) {
      audioRef.current.currentTime = (val / 100) * duration;
    }
  };

  const onTimeUpdate = () => {
    if (audioRef.current) {
      const current = audioRef.current.currentTime;
      const dur = audioRef.current.duration;
      setCurrentPlayTime(current);
      setDuration(dur || 0);
      if (dur) setProgress((current / dur) * 100);
    }
  };

  const onTrackEnd = () => {
    setIsPlaying(false);
    handleSkipForward();
  };

  // --- 3. 交互按键逻辑 ---
  const handleSkipForward = () => {
    if (wsRef.current && wsConnected) {
      wsRef.current.send(JSON.stringify({ type: 'command', action: 'next_track' }));
      setDjMessage("正在为您生成下一首歌曲...");
      setIsPlaying(false);
      if(audioRef.current) audioRef.current.pause();
    }
  };

  const handleSkipBack = () => {
    if (audioRef.current) audioRef.current.currentTime = 0; 
    if (!isPlaying) togglePlay();
  };

  const handleStop = () => {
    if (audioRef.current) {
      audioRef.current.pause();
      audioRef.current.currentTime = 0;
    }
    setIsPlaying(false);
  };

  const handleSendMessage = () => {
    if (!inputText.trim() || !wsConnected) return;
    wsRef.current.send(JSON.stringify({ type: 'user_input', text: inputText }));
    setDjMessage(`用户: ${inputText} ... (DJ 思考中)`);
    setInputText("");
  };

  // --- 4. 辅助功能 ---
  const playDJSynthesis = (text, callback) => {
    if (!window.speechSynthesis) return callback();
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(text);
    const voices = window.speechSynthesis.getVoices();
    const zhVoice = voices.find(v => v.lang.includes('zh') && v.name.includes('Xiaoxiao')) || voices.find(v => v.lang.includes('zh'));
    if (zhVoice) utterance.voice = zhVoice;
    
    utterance.rate = 0.95;
    utterance.onstart = () => setIsDJSpeaking(true);
    utterance.onend = () => {
      setIsDJSpeaking(false);
      callback();
    };
    window.speechSynthesis.speak(utterance);
  };

  useEffect(() => {
    const timer = setInterval(() => setCurrentTime(new Date()), 1000);
    return () => clearInterval(timer);
  }, []);

  const formatTimeStr = (seconds) => {
    if (!seconds || isNaN(seconds)) return "0:00";
    const m = Math.floor(seconds / 60);
    const s = Math.floor(seconds % 60).toString().padStart(2, '0');
    return `${m}:${s}`;
  };

  const formatDate = (date) => {
    const options = { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' };
    return date.toLocaleDateString('zh-CN', options);
  };

  // --- 修复的主题色彩类名 ---
  const isDark = theme === 'dark';
  const bgMain = isDark ? 'bg-gray-900' : 'bg-gray-200';
  const bgCard = isDark ? 'bg-gray-800' : 'bg-white';
  const textPrimary = isDark ? 'text-white' : 'text-gray-900';
  const textSecondary = isDark ? 'text-gray-400' : 'text-gray-600';
  const borderCol = isDark ? 'border-gray-700' : 'border-gray-300';

  return (
    <div className={`min-h-screen ${bgMain} ${textSecondary} font-sans transition-colors duration-500`}>
      
      {/* 修复的CSS样式 */}
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=VT323&display=swap');
        
        .font-pixel {
          font-family: 'VT323', monospace;
        }

        .halo-container {
          position: relative;
          z-index: 10;
        }

        .halo-container::before {
          content: "";
          position: absolute;
          inset: -10px;
          background: linear-gradient(124deg, #ff0000, #ff7f00, #ffff00, #7fff00, #00ff00, #00ff7f, #00ffff, #007fff, #0000ff, #7f00ff, #ff00ff, #ff007f, #ff0000);
          background-size: 600% 600%;
          animation: halo-rotation 25s ease-in-out infinite;
          z-index: -1;
          border-radius: 16px;
          pointer-events: none;
          opacity: 0.3;
        }

        @keyframes halo-rotation {
          0%, 100% { background-position: 0% 50%; }
          50% { background-position: 100% 50%; }
        }

        .dot-matrix-bg {
          background-image: radial-gradient(circle, rgba(255,255,255,0.05) 1px, transparent 1px);
          background-size: 12px 12px;
        }

        .line-clamp-1 {
          overflow: hidden;
          display: -webkit-box;
          -webkit-box-orient: vertical;
          -webkit-line-clamp: 1;
        }
      `}</style>

      <audio ref={audioRef} onTimeUpdate={onTimeUpdate} onEnded={onTrackEnd} preload="auto" />

      {/* 外层容器 - 移除了动态缩放 */}
      <div className={`${isDark ? 'halo-container' : 'shadow-2xl'} max-w-4xl mx-auto`}>
        {/* 内层主UI容器 */}
        <div className={`${bgCard} rounded-lg overflow-hidden flex flex-col relative border ${borderCol} shadow-xl min-h-screen`}>
          
          {/* 介绍板块 */}
          {showIntro && (
            <div className="absolute inset-0 z-50 bg-black/90 backdrop-blur-md flex flex-col justify-center items-center p-8">
              <h2 className="text-4xl font-pixel text-green-400 mb-6">Versior AI</h2>
              <div className="bg-gray-900 border border-gray-700 p-6 rounded-lg max-w-md text-center">
                <p className="text-sm text-gray-300 leading-loose mb-4">
                  欢迎来到 <span className="text-green-400 font-bold">Versior</span>，您的专属全自动 AI 电台。
                </p>
                <p className="text-xs text-gray-400 leading-relaxed text-left space-y-2">
                  <span className="block">• <strong>大脑：</strong>由 LongCat-Flash-Lite MoE 模型强力驱动。</span>
                  <span className="block">• <strong>音乐：</strong>无缝接入全球音乐 API 数据源。</span>
                  <span className="block">• <strong>情境：</strong>智能感知您的作息节律、天气与音乐品味。</span>
                  <span className="block">• <strong>声音：</strong>实时神经网络语音合成。</span>
                </p>
              </div>
              <button 
                onClick={() => setShowIntro(false)} 
                className="mt-8 border border-gray-600 text-gray-400 px-8 py-2.5 rounded-full hover:bg-gray-800 hover:text-white transition-all font-bold tracking-widest text-xs uppercase"
              >
                关闭系统
              </button>
            </div>
          )}

          {/* 系统状态板块 */}
          {showSettings && (
            <div className="absolute inset-0 z-50 bg-black/90 backdrop-blur-md flex flex-col justify-center items-center p-8">
              <h2 className="text-3xl font-pixel text-green-400 mb-8 uppercase">系统状态</h2>
              
              <div className="bg-gray-900 w-full max-w-sm border border-gray-700 p-6 rounded-lg text-left space-y-6">
                
                {/* 1. 后端状态 */}
                <div className="flex justify-between items-center border-b border-gray-700 pb-4">
                  <div>
                    <h3 className="text-sm text-gray-200 font-bold">后端服务器</h3>
                    <p className="text-xs text-gray-500 mt-1 font-mono">WS://LOCALHOST:8834</p>
                  </div>
                  <div className="flex items-center gap-2">
                    {wsConnected ? (
                      <span className="text-green-400 text-xs font-bold uppercase">已连接</span>
                    ) : (
                      <span className="text-red-500 text-xs font-bold uppercase">已断开</span>
                    )}
                    <div className={`w-2 h-2 rounded-full ${wsConnected ? 'bg-green-400' : 'bg-red-500'}`}></div>
                  </div>
                </div>

                {/* 2. 模型状态 */}
                <div className="flex justify-between items-center border-b border-gray-700 pb-4">
                  <div>
                    <h3 className="text-sm text-gray-200 font-bold">大语言模型引擎</h3>
                    <p className="text-xs text-gray-500 mt-1 font-mono">LONGCAT-FLASH-LITE</p>
                  </div>
                  <div className="flex items-center gap-2">
                    <span className="text-green-400 text-xs font-bold uppercase">待机中</span>
                    <div className="w-2 h-2 rounded-full bg-green-400"></div>
                  </div>
                </div>

                {/* 3. 音乐 API 状态 */}
                <div className="flex justify-between items-center">
                  <div>
                    <h3 className="text-sm text-gray-200 font-bold">音乐 API (网易云)</h3>
                    <p className="text-xs text-gray-500 mt-1 font-mono">IWENWIKI.COM:3000</p>
                  </div>
                  <div className="flex items-center gap-2">
                    <span className="text-green-400 text-xs font-bold uppercase">活跃</span>
                    <div className="w-2 h-2 rounded-full bg-green-400"></div>
                  </div>
                </div>

              </div>

              <button 
                onClick={() => setShowSettings(false)} 
                className="mt-10 border border-gray-600 text-gray-400 px-8 py-2.5 rounded-full hover:bg-gray-800 hover:text-white transition-all font-bold tracking-widest text-xs uppercase"
              >
                关闭设置
              </button>
            </div>
          )}

          {/* Header */}
          <div className="px-6 py-5 flex justify-between items-center">
            <h1 className={`text-3xl tracking-widest font-pixel ${textPrimary} uppercase`}>
              Versior
            </h1>
            <div className="flex items-center gap-2">
              <button 
                onClick={() => setShowIntro(true)}
                className="text-xs tracking-widest text-gray-400 hover:text-white transition-colors uppercase border border-gray-700 rounded-full px-3 py-1.5 flex items-center gap-1"
              >
                <Info className="w-3 h-3" /> 关于
              </button>
              
              <button 
                onClick={() => setShowSettings(true)}
                className="text-xs tracking-widest text-gray-400 hover:text-white transition-colors uppercase border border-gray-700 rounded-full px-3 py-1.5 flex items-center gap-1"
              >
                <Settings className="w-3 h-3" /> 设置
              </button>

              <div className={`flex ${isDark ? 'bg-gray-900' : 'bg-gray-100'} rounded-full p-1 border ${borderCol} ml-2`}>
                <button onClick={() => setTheme('dark')} className={`${isDark ? 'bg-white text-black' : 'text-gray-500 hover:text-black'} text-xs font-bold px-3 py-1 rounded-full uppercase transition-all`}>
                  暗色
                </button>
                <button onClick={() => setTheme('light')} className={`${!isDark ? 'bg-black text-white' : 'text-gray-500 hover:text-white'} text-xs font-bold px-3 py-1 rounded-full uppercase transition-all`}>
                  亮色
                </button>
              </div>
            </div>
          </div>

          {/* 时钟与状态区 */}
          <div className={`relative h-32 border-y ${borderCol} ${isDark ? 'bg-gray-900 dot-matrix-bg' : 'bg-gray-50'} flex flex-col justify-center items-center`}>
            {/* 像素时钟 */}
            <div className={`text-5xl font-pixel tracking-widest ${textPrimary} mb-2`}>
              {currentTime.getHours().toString().padStart(2, '0')}
              <span className="mx-2 opacity-50">:</span>
              {currentTime.getMinutes().toString().padStart(2, '0')}
            </div>
            
            <div className="text-xs text-gray-500 tracking-widest uppercase font-medium mt-2">
              {formatDate(currentTime)}
            </div>
            
            <div className="mt-4 flex items-center gap-2 text-xs font-bold tracking-widest uppercase text-green-400">
              <span className={`w-2 h-2 rounded-full bg-green-400 ${wsConnected ? 'animate-pulse' : 'opacity-30'}`}></span>
              {wsConnected ? '直播中' : '离线'}
            </div>
          </div>

          {/* 播放控制台 */}
          <div className={`px-6 py-5 ${isDark ? 'bg-gray-800' : 'bg-gray-100'}`}>
            <div className="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-4 gap-4">
              
              <div className="flex items-center gap-4">
                {/* 波形图 */}
                <div className={`flex items-end h-6 gap-1 ${isPlaying ? 'opacity-100' : 'opacity-40'} transition-opacity`}>
                  <div className={`w-1.5 h-3 bg-green-400 ${isPlaying ? 'animate-pulse' : ''} rounded-sm`}></div>
                  <div className={`w-1.5 h-6 bg-green-400 ${isPlaying ? 'animate-pulse' : ''} rounded-sm`}></div>
                  <div className={`w-1.5 h-4 bg-green-400 ${isPlaying ? 'animate-pulse' : ''} rounded-sm`}></div>
                  <div className={`w-1.5 h-5 bg-green-400 ${isPlaying ? 'animate-pulse' : ''} rounded-sm`}></div>
                </div>
                <div>
                  <h2 className={`text-sm font-bold ${textPrimary} line-clamp-1`}>{currentTrack.title} - {currentTrack.artist}</h2>
                  <p className="text-xs tracking-widest text-gray-500 uppercase mt-1">正在播放</p>
                </div>
              </div>

              {/* 控制按钮组 */}
              <div className="flex items-center gap-3">
                <button onClick={handleSkipBack} className={`w-8 h-8 rounded-full border ${borderCol} flex justify-center items-center hover:text-green-400 hover:border-green-400 transition-all`}><SkipBack className="w-3.5 h-3.5 fill-current" /></button>
                <button onClick={togglePlay} className={`w-8 h-8 rounded-full border ${borderCol} flex justify-center items-center hover:text-green-400 hover:border-green-400 transition-all`}>
                  {isPlaying ? <Pause className="w-3.5 h-3.5 fill-current" /> : <Play className="w-3.5 h-3.5 fill-current ml-0.5" />}
                </button>
                <button onClick={handleSkipForward} className={`w-8 h-8 rounded-full border ${borderCol} flex justify-center items-center hover:text-green-400 hover:border-green-400 transition-all`}><SkipForward className="w-3.5 h-3.5 fill-current" /></button>
                <button onClick={handleStop} className={`w-8 h-8 rounded-full border ${borderCol} flex justify-center items-center hover:text-green-400 hover:border-green-400 transition-all`}><Square className="w-3.5 h-3.5 fill-current" /></button>
                
                {/* 音量控制 */}
                <div className="flex items-center gap-2 ml-2">
                  <Volume2 className="w-3.5 h-3.5 text-gray-500" />
                  <input type="range" min="0" max="100" value={volume} onChange={handleVolumeChange} className="w-16 h-1 bg-gray-600 rounded-full appearance-none cursor-pointer" />
                </div>
              </div>
            </div>

            {/* 进度条 */}
            <div className="flex items-center justify-between text-xs font-mono text-gray-500 mb-1">
              <span>{formatTimeStr(currentPlayTime)}</span>
              <span>{formatTimeStr(duration || 178)}</span>
            </div>
            <input 
              type="range" min="0" max="100" value={progress} onChange={handleProgressChange}
              className="w-full h-1 bg-gray-700 rounded-full appearance-none cursor-pointer"
              style={{ background: `linear-gradient(to right, #22c55e ${progress}%, #374151 ${progress}%)` }}
            />
          </div>

          {/* 播放列表 */}
          <div className={`${isDark ? 'bg-gray-900' : 'bg-gray-50'} border-t ${borderCol}`}>
            <div className={`flex justify-between px-6 py-2.5 text-xs tracking-widest border-b ${borderCol} text-gray-500`}>
              <span>播放列表</span>
              <span>{queue.length} 首曲目</span>
            </div>
            <div className="flex flex-col">
              {queue.slice(0, 5).map((track, idx) => {
                const isActive = currentTrack.title === track.title || track.active;
                return (
                  <div key={idx} onClick={() => loadAndPlayTrack(track)} className={`flex items-center justify-between px-6 py-2.5 text-xs border-l-2 ${isActive ? 'border-green-400 bg-green-400/10' : 'border-transparent hover:bg-gray-700/30'} cursor-pointer transition-colors`}>
                    <div className="flex items-center gap-4">
                      {isActive ? (
                        <Play className="w-3 h-3 text-green-400 fill-current" />
                      ) : (
                        <span className="text-gray-500 font-mono w-3 text-right">{idx + 1}</span>
                      )}
                      <span className={isActive ? 'text-gray-200 font-medium' : 'text-gray-400'}>{track.title}</span>
                    </div>
                    <span className={`text-xs ${isActive ? 'text-green-400/80' : 'text-gray-500'}`}>{track.artist}</span>
                  </div>
                );
              })}
            </div>
          </div>

          {/* DJ 交互区 */}
          <div className={`p-6 ${isDark ? 'bg-gray-800' : 'bg-white'} border-t ${borderCol}`}>
            <div className="flex justify-between items-center mb-4">
              <div className="flex items-center gap-2">
                <span className="w-2 h-2 rounded-full bg-green-400"></span>
                <span className="text-xs font-pixel tracking-widest uppercase text-gray-300">Claudio</span>
              </div>
              <div className="flex gap-1 h-3 items-end">
                <div className={`w-1 bg-green-400 rounded-sm ${isDJSpeaking ? 'animate-pulse h-3' : 'h-1'}`}></div>
                <div className={`w-1 bg-green-400 rounded-sm ${isDJSpeaking ? 'animate-pulse h-2' : 'h-1'}`}></div>
                <div className={`w-1 bg-green-400 rounded-sm ${isDJSpeaking ? 'animate-pulse h-3' : 'h-1'}`}></div>
              </div>
            </div>

            <div className="flex gap-4">
              <div className={`w-10 h-10 rounded-full border ${borderCol} overflow-hidden shrink-0 relative`}>
                <img src="https://images.unsplash.com/photo-1570295999919-56ceb5ecca61?auto=format&fit=crop&q=80&w=100&h=100" alt="DJ Avatar" className="w-full h-full object-cover" />
                {isDJSpeaking && <div className="absolute inset-0 bg-green-400/30 animate-pulse"></div>}
              </div>
              
              <div className={`flex-1 ${isDark ? 'bg-gray-700' : 'bg-gray-100'} rounded-2xl rounded-tl-none p-4 border ${borderCol}`}>
                <p className={`text-sm ${textPrimary} leading-relaxed font-sans`}>{djMessage}</p>
                <div className="mt-4 flex items-center gap-3">
                  <span className="text-xs text-gray-500 font-mono">{formatTimeStr(currentTime.getHours() * 60 + currentTime.getMinutes())}</span>
                  <div className={`flex items-center gap-1.5 border border-green-400/30 px-2.5 py-0.5 rounded-full ${isDJSpeaking ? 'bg-green-400/10' : 'bg-green-400/5'}`}>
                    {isDJSpeaking ? <Mic className="w-2.5 h-2.5 text-green-400 animate-pulse" /> : <Pause className="w-2.5 h-2.5 text-green-400 fill-current" />}
                    <span className="text-xs text-green-400 font-bold tracking-widest">{isDJSpeaking ? '说话中' : '播放中'}</span>
                  </div>
                </div>
              </div>
            </div>

            {/* 发送消息框 */}
            <div className="mt-6 relative flex items-center">
              <input 
                type="text" 
                placeholder="对 DJ 说点什么..."
                value={inputText}
                onChange={(e) => setInputText(e.target.value)}
                onKeyDown={(e) => e.key === 'Enter' && handleSendMessage()}
                className={`w-full ${isDark ? 'bg-gray-700 text-gray-200' : 'bg-gray-100 text-gray-900'} border ${borderCol} rounded-xl py-3 pl-4 pr-24 text-sm focus:outline-none focus:border-green-400 transition-colors`}
              />
              <div className="absolute right-2 top-1/2 -translate-y-1/2 flex items-center gap-2">
                <button className="p-2 text-gray-500 hover:text-gray-300 transition-colors"><Mic className="w-4 h-4" /></button>
                <button 
                  onClick={handleSendMessage}
                  disabled={!wsConnected}
                  className={`w-8 h-8 rounded-lg flex items-center justify-center transition-colors ${wsConnected ? 'bg-green-400 text-black hover:bg-green-500' : 'bg-gray-600 text-gray-400 cursor-not-allowed'}`}
                >
                  <ArrowUp className="w-4 h-4" />
                </button>
              </div>
            </div>
          </div>

          {/* Footer */}
          <div className={`px-6 py-4 flex justify-between text-xs tracking-widest text-gray-500 font-mono uppercase ${isDark ? 'bg-gray-900' : 'bg-gray-100'} border-t ${borderCol}`}>
            <span>Versior FM</span>
            <span className={wsConnected ? 'text-green-400' : 'text-gray-500'}>
              {wsConnected ? '已连接' : '已断开'}
            </span>
          </div>

        </div>
      </div>
    </div>
  );
}